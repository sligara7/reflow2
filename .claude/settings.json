{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/tools/loop_nudge.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__reflow2__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/tools/loop_nudge.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/tools/loop_nudge.py\""
          }
        ]
      }
    ]
  }
}
