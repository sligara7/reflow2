# Rust
/target

# Self-host: reflow2's own graph is a RocksDB directory, and .mcp.json carries an
# absolute path to a local debug build. Both are per-machine, not shared state.
/.reflow2/
/.mcp.json


# Trial records about real systems (storyflow, ophyd-service, personal projects)
# stay out of the public repo: they describe designs that are not reflow2's to
# publish. Kept locally; the public evidence base is the reflow2-self trials.
/docs/trials-private/
